{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://salvarecuero.dev https://www.salvarecuero.dev http://localhost:4321" }
      ]
    }
  ]
}
